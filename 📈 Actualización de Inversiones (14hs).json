      "parameters": {
        "jsCode": "const now = new Date(new Date().toLocaleString('en-US', { timeZone: 'America/Argentina/Buenos_Aires' }));\nconst dayOfWeek = now.getDay();\nconst esHabil = dayOfWeek >= 1 && dayOfWeek <= 5;\nreturn { esHabil, diaSemana: dayOfWeek };"
