    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT\n  COALESCE(\n    (SELECT b.saldo_actual\n     FROM finanzas_personales.billeteras b\n     JOIN finanzas_personales.tipos_billetera tb ON b.tipo_billetera_id = tb.id\n     WHERE tb.codigo = 'FONDO_JUAN' LIMIT 1),\n    0\n  ) AS saldo_actual,\n  (\n    SELECT hb.registrado_en\n    FROM finanzas_personales.billeteras b\n    JOIN finanzas_personales.tipos_billetera tb ON b.tipo_billetera_id = tb.id\n    LEFT JOIN finanzas_personales.historial_billeteras hb ON b.id = hb.billetera_id\n    WHERE tb.codigo = 'FONDO_JUAN'\n    ORDER BY hb.registrado_en DESC NULLS LAST\n    LIMIT 1\n  ) AS ultima_actualizacion;",
        "options": {}
      },
