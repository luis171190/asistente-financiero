# ============================================================================
# Asistente Financiero - Variables de entorno (template)
# Copiar a .env.local y completar con valores reales. NUNCA commitear .env.local
# ============================================================================

# n8n self-hosted (donde corren los workflows)
N8N_BASE_URL=https://your-n8n-instance.example.com
N8N_API_KEY=

# OpenAI / Anthropic (LLM del agente financiero)
OPENAI_API_KEY=sk-...
# o:
ANTHROPIC_API_KEY=sk-ant-...

# Evolution API (WhatsApp gateway)
EVOLUTION_API_URL=https://your-evolution-instance.example.com
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE_NAME=

# Numero WhatsApp del usuario destino del asistente (formato internacional sin +)
WA_USER_PHONE=54XXXXXXXXXX

# Supabase / Postgres (memoria del agente + storage de gastos)
DATABASE_URL=postgresql://user:pass@host:5432/dbname
SUPABASE_URL=
SUPABASE_ANON_KEY=
